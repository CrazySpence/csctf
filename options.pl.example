#!/usr/bin/perl
# options.pl.example — copy this to options.pl and fill in your values
# options.pl is gitignored so your credentials are never committed.

%OPTIONS = (
        DD_BUILD    => "0.2.0",
        MIN_VERSION => "0.2.0",
        DEBUG       => 1,
        DB_HOST     => "localhost",
        DB_PORT     => 3306,
        DB_USER     => "",       # your MySQL username
        DB_PASS     => "",       # your MySQL password
        DB_DB       => "",       # your database name
        STATE_FILE  => "./ctfstate.dat",
    );

return true;
